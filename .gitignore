# ============ Project-Specific ============
# Datasets and model weights (large files; do not commit)
/data
/models
/runs/

# ML artifacts (large files; do not commit)
artifacts/
*.safetensors
*.bin
*.pt
*.pth
*.onnx

# Datasets (large; download via scripts/data)
data/raw/
data/mpid-v1/images/
data/mpid-v1-zerowidth/images/
data/mpid-v1-crossmodal/images/
data/mpid-v1/*.parquet
data/mpid-v1-zerowidth/*.parquet
data/mpid-v1-crossmodal/*.parquet

# OCR / CLIP model caches (downloaded at runtime)
.ocr_cache/
.clip_cache/
.paddleocr/

# Experiment logs
mlruns/
wandb/
logs/
*.log

# Offline package output (generated by scripts/package_offline.py).
# mpid_offline*/ glob matches both legacy (mpid_offline) and versioned
# (mpid_offline_v2/) build outputs. These are large (≈1 GB with
# backbone weights) and intended to be published as GitHub Release
# assets, not committed to git.
mpid_offline*/
*.tar.gz
*.zip

# Generated reports
report/figures/*.png
report/ci_*.json
report/eval_*.json

# Demo screenshots (generated by demo/smoke_pipeline.py and the Gradio app)
demo/screenshots/

# Jupyter / IPython notebooks in research
notebooks/.ipynb_checkpoints/

